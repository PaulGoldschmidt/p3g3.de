{{!-- Command Palette overlay --}}
<div class="cmd-palette-overlay" id="cmd-palette" role="dialog" aria-modal="true" aria-label="{{t "Command palette"}}" hidden>
    <div class="cmd-palette-backdrop"></div>
    <div class="cmd-palette-dialog">
        <div class="cmd-palette-header">
            <svg class="cmd-palette-search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="cmd-palette-input" type="text" placeholder="{{t "Type a command or search..."}}" aria-label="{{t "Type a command or search..."}}" autocomplete="off" spellcheck="false">
        </div>
        <ul class="cmd-palette-results" role="listbox" aria-label="Results"></ul>
        <div class="cmd-palette-empty" hidden>{{t "No results"}}</div>
        <div class="cmd-palette-footer">
            <span><kbd>&uarr;&darr;</kbd> {{t "navigate"}}</span>
            <span><kbd>&crarr;</kbd> {{t "select"}}</span>
            <span><kbd>esc</kbd> {{t "close"}}</span>
        </div>
    </div>
</div>

{{!-- Pre-rendered post index for palette search --}}
<div id="palette-posts" hidden>
    {{#get "posts" limit="all"}}
        {{#foreach posts}}
            <span data-title="{{title}}" data-url="{{url}}" data-tag="{{#if primary_tag}}{{primary_tag.name}}{{/if}}"></span>
        {{/foreach}}
    {{/get}}
</div>
