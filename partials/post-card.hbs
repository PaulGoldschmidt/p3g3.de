<article class="post-card {{post_class}} {{#unless feature_image}}no-image{{/unless}}">
    <a class="post-card-link" href="{{url}}">
        {{#if feature_image}}
            <div class="post-card-image">
                <img
                    srcset="{{img_url feature_image size="xs" format="webp"}} 160w,
                            {{img_url feature_image size="s" format="webp"}} 320w"
                    sizes="120px"
                    src="{{img_url feature_image size="s"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    {{#if lazyLoad}}loading="lazy"{{/if}}
                >
            </div>
        {{/if}}
        <div class="post-card-content">
            <h3 class="post-card-title">{{title}}</h3>
            <div class="post-card-meta">
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                {{#if @custom.show_reading_time}}
                    {{#if reading_time}}
                        <span class="bull">&middot;</span>
                        <span>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                    {{/if}}
                {{/if}}
                {{#if @site.members_enabled}}
                    {{#has visibility="paid"}}
                        <span class="bull">&middot;</span>
                        <span class="member-lock">{{> "icons/lock"}}</span>
                    {{/has}}
                {{/if}}
            </div>
            {{#if custom_excerpt}}
                <p class="post-card-excerpt">{{custom_excerpt}}</p>
            {{else if excerpt}}
                <p class="post-card-excerpt">{{excerpt words="25"}}</p>
            {{/if}}
        </div>
    </a>
</article>
