<!DOCTYPE html>
<html lang="{{@site.locale}}" data-theme="dark">
<head>

    <title>{{meta_title page=(t " (Page %)")}}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {{!-- Preload critical assets --}}
    <link rel="preload" as="style" href="{{asset "built/screen.css"}}">
    <link rel="preload" href="{{asset "fonts/Geist-Variable.woff2"}}" as="font" type="font/woff2" crossorigin>

    {{!-- Theme stylesheet --}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}">

    {{!-- Set theme before paint to avoid flash --}}
    <script>
        (function () {
            var stored = localStorage.getItem("theme");
            if (stored) {
                document.documentElement.setAttribute("data-theme", stored);
            }
        })();
    </script>

    {{!-- Background color that fades over 24h between 3 colors per theme --}}
    <script>
        (function () {
            var dark  = [[15,23,42],[0,1,3],[12,38,66]];
            var light = [[237,237,233],[245,235,224],[227,213,202]];

            function lerp(a, b, t) {
                return Math.round(a + (b - a) * t);
            }

            function toHex(r, g, b) {
                return "#" + ((1<<24)+(r<<16)+(g<<8)+b).toString(16).slice(1);
            }

            function getColor(palette, hour, min) {
                var t = (hour + min / 60) / 24;
                var seg = t * 3;
                var i = Math.floor(seg) % 3;
                var f = seg - Math.floor(seg);
                var a = palette[i];
                var b = palette[(i + 1) % 3];
                return [lerp(a[0],b[0],f), lerp(a[1],b[1],f), lerp(a[2],b[2],f)];
            }

            function apply() {
                var now = new Date();
                var theme = document.documentElement.getAttribute("data-theme") || "dark";
                var palette = theme === "light" ? light : dark;
                var rgb = getColor(palette, now.getHours(), now.getMinutes());
                var hex = toHex(rgb[0], rgb[1], rgb[2]);
                document.documentElement.style.setProperty("--bg", hex);
            }

            apply();
            document.addEventListener("DOMContentLoaded", apply);
            setInterval(apply, 60000);
            window.__applyBgColor = apply;
        })();
    </script>

    {{!-- Midnight party mode — 15s of vibrant color cycling at 00:00 --}}
    <script>
        (function () {
            function msUntilMidnight() {
                var now = new Date();
                var midnight = new Date(now);
                midnight.setHours(24, 0, 0, 0);
                return midnight - now;
            }

            function startParty(duration) {
                var start = performance.now();
                var ms = duration * 1000;
                document.documentElement.classList.add("party-mode");

                function frame(ts) {
                    var elapsed = ts - start;
                    if (elapsed >= ms) {
                        document.documentElement.classList.remove("party-mode");
                        if (window.__applyBgColor) window.__applyBgColor();
                        setTimeout(function () { startParty(15); }, msUntilMidnight());
                        return;
                    }
                    var hue = (elapsed / 2000 * 360) % 360;
                    var theme = document.documentElement.getAttribute("data-theme") || "dark";
                    var l = theme === "light" ? "65%" : "25%";
                    document.documentElement.style.setProperty("--bg", "hsl(" + hue + ", 100%, " + l + ")");
                    requestAnimationFrame(frame);
                }

                requestAnimationFrame(frame);
            }

            window.__party = function () { startParty(40); };

            var now = new Date();
            if (now.getHours() === 0 && now.getMinutes() === 0 && now.getSeconds() < 15) {
                startParty(15 - now.getSeconds());
            } else {
                setTimeout(function () { startParty(15); }, msUntilMidnight());
            }
        })();
    </script>

    {{!-- Matomo analytics (only if site ID is configured) --}}
    {{#if @custom.matomo_site_id}}
    <script>
        var _paq = window._paq = window._paq || [];
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function() {
            var u="https://analytics.dotreflection.com/";
            _paq.push(['setTrackerUrl', u+'matomo.php']);
            _paq.push(['setSiteId', '{{@custom.matomo_site_id}}']);
            var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
            g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
        })();
    </script>
    {{/if}}

    {{!-- Ghost head (SEO, structured data, etc.) --}}
    {{ghost_head}}

</head>
<body class="{{body_class}}">

<div class="gh-viewport">

    {{> "sidebar"}}
    {{> "navigation"}}

    <main class="gh-main appear" style="--delay: 1">
        {{{body}}}
    </main>

    {{> "footer"}}

</div>

{{!-- Theme scripts --}}
<script defer src="{{asset "built/main.js"}}"></script>

{{!-- Ghost foot (portal, search, etc.) --}}
{{ghost_foot}}

</body>
</html>
